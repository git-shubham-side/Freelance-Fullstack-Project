<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ContactMe Services | Landing</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,600;1,400&display=swap"
      rel="stylesheet"
    />

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />

    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet" />

    <style>
      /* --- PREMIUM ENTERPRISE CODAVER VARIABLES --- */
      :root {
        --bg-main: #0b0f17;
        --bg-surface: #131a26;
        --bg-light: #f8fafc;
        --text-pure: #ffffff;
        --text-muted: #94a3b8;
        --text-dark: #0f172a;
        --text-dark-muted: #475569;

        --accent: #c29b68;
        --accent-hover: #b08856;

        --border-color: rgba(255, 255, 255, 0.08);
        --border-focus: rgba(194, 155, 104, 0.5);

        /* Strict Sharp Theme: Absolute Sharp Corners */
        --sharp: 0px;
      }

      /* --- GLOBAL RESETS --- */
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: "Plus Jakarta Sans", sans-serif;
        border-radius: var(--sharp) !important;
      }

      body {
        background-color: var(--bg-main);
        color: var(--text-pure);
        overflow-x: hidden;
        line-height: 1.6;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        position: relative;
      }

      h1,
      h2,
      h3,
      .brand-logo {
        font-weight: 700;
        letter-spacing: -0.03em;
      }

      .serif-italic {
        font-family: "Playfair Display", serif;
        font-style: italic;
        font-weight: 400;
      }

      /* --- CUSTOM CURSOR --- */
      #custom-cursor {
        width: 20px;
        height: 20px;
        border: 2px solid var(--accent);
        position: fixed;
        transform: translate(-50%, -50%);
        pointer-events: none;
        z-index: 9999;
        mix-blend-mode: difference;
        transition:
          width 0.2s,
          height 0.2s,
          background-color 0.2s;
      }

      /* --- BACKGROUND GLOW ORBS --- */
      .glow-orb {
        position: absolute;
        width: 50vw;
        height: 50vw;
        max-width: 500px;
        max-height: 500px;
        background: radial-gradient(
          circle,
          rgba(194, 155, 104, 0.06) 0%,
          rgba(0, 0, 0, 0) 70%
        );
        pointer-events: none;
        z-index: -1;
        animation: pulseGlow 8s infinite alternate;
      }

      .glow-orb.orb-1 {
        top: -10%;
        left: -10%;
      }
      .glow-orb.orb-2 {
        bottom: 10%;
        right: -10%;
        animation-delay: -4s;
      }

      @keyframes pulseGlow {
        0% {
          transform: scale(1);
          opacity: 0.5;
        }
        100% {
          transform: scale(1.1);
          opacity: 1;
        }
      }

      /* --- UTILITIES & BUTTONS --- */
      .section-tag {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: var(--accent);
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 1.5rem;
        font-weight: 600;
        background: var(--bg-surface);
        padding: 0.5rem 1rem;
        border: 1px solid var(--border-color);
      }

      .status-dot {
        width: 8px;
        height: 8px;
        background-color: var(--accent);
        box-shadow: 0 0 10px var(--accent);
        animation: blink 1.5s infinite;
      }

      @keyframes blink {
        0%,
        100% {
          opacity: 1;
        }
        50% {
          opacity: 0.4;
        }
      }

      .btn-premium {
        position: relative;
        background: var(--accent);
        color: var(--bg-main);
        padding: 0.85rem 2rem;
        border: none;
        font-weight: 600;
        font-size: 0.9rem;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        text-decoration: none;
        letter-spacing: 0.02em;
        overflow: hidden;
        z-index: 1;
        transition:
          transform 0.3s ease,
          box-shadow 0.3s ease;
      }

      .btn-premium::before {
        content: "";
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: var(--text-pure);
        transition: left 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        z-index: -1;
      }

      .btn-premium:hover::before {
        left: 0;
      }
      .btn-premium:hover {
        color: var(--bg-main);
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(194, 155, 104, 0.2);
      }

      .btn-outline {
        background: transparent;
        border: 1px solid var(--border-color);
        color: var(--text-pure);
      }

      .btn-outline::before {
        background: var(--text-pure);
      }
      .btn-outline:hover {
        color: var(--bg-main) !important;
        border-color: var(--text-pure);
      }

      /* --- HEADER --- */
      header {
        width: 100%;
        padding: 1.5rem 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        z-index: 10;
        border-bottom: 1px solid var(--border-color);
        background: rgba(11, 15, 23, 0.8);
        backdrop-filter: blur(10px);
        position: sticky;
        top: 0;
      }

      .brand-logo {
        font-size: 1.5rem;
        color: var(--text-pure);
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .brand-logo span {
        color: var(--accent);
      }

      /* --- MAIN CONTENT & HERO --- */
      main {
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 5rem 2rem;
        max-width: 1400px;
        margin: 0 auto;
        width: 100%;
        text-align: center;
        z-index: 2;
      }

      .hero-title {
        font-size: clamp(3rem, 6vw, 5rem);
        line-height: 1.1;
        margin-bottom: 1.5rem;
      }

      .hero-title .serif-italic {
        color: var(--accent);
      }

      .hero-desc {
        font-size: clamp(1rem, 2vw, 1.2rem);
        color: var(--text-muted);
        max-width: 600px;
        margin: 0 auto 4rem auto;
      }

      /* --- LIVE STATS DASHBOARD --- */
      .stats-panel {
        background: var(--bg-surface);
        border: 1px solid var(--border-color);
        width: 100%;
        max-width: 900px;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        margin-bottom: 5rem;
      }

      .stat-item {
        padding: 2.5rem 2rem;
        border-right: 1px solid var(--border-color);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
      }

      .stat-item:last-child {
        border-right: none;
      }

      .stat-value {
        font-size: clamp(2rem, 4vw, 3rem);
        font-weight: 700;
        color: var(--text-pure);
        line-height: 1;
        margin-bottom: 0.5rem;
        font-family: "Playfair Display", serif;
      }

      .stat-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--accent);
        font-weight: 600;
      }

      /* --- BUSINESS CARDS PORTAL --- */
      .portal-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(min(100%, 350px), 1fr));
        gap: 2.5rem;
        width: 100%;
      }

      .portal-card {
        background: var(--bg-surface);
        border: 1px solid var(--border-color);
        padding: 3rem 2.5rem;
        display: flex;
        flex-direction: column;
        text-align: left;
        transition: all 0.4s ease;
        position: relative;
        overflow: hidden;
      }

      .portal-card::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 3px;
        background: var(--accent);
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.4s ease;
      }

      .portal-card:hover {
        border-color: var(--accent);
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
      }

      .portal-card:hover::before {
        transform: scaleX(1);
      }

      .card-icon-wrapper {
        width: 60px;
        height: 60px;
        background: rgba(194, 155, 104, 0.1);
        border: 1px solid var(--border-focus);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        color: var(--accent);
        margin-bottom: 2rem;
      }

      .portal-card h3 {
        font-size: 1.5rem;
        margin-bottom: 1rem;
      }

      .portal-card p {
        color: var(--text-muted);
        font-size: 0.95rem;
        flex-grow: 1;
        margin-bottom: 2rem;
      }

      .feature-icons {
        display: flex;
        gap: 1rem;
        color: var(--text-muted);
        margin-bottom: 2.5rem;
        font-size: 1.2rem;
      }

      .portal-card .btn-premium {
        width: 100%;
      }

      /* --- FOOTER --- */
      footer {
        background: #06090e;
        border-top: 1px solid var(--border-color);
        padding: 4rem 2rem 2rem;
        text-align: center;
        z-index: 10;
      }

      .footer-brand {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--text-pure);
        margin-bottom: 2rem;
      }

      .footer-contact {
        display: flex;
        justify-content: center;
        gap: 2rem;
        flex-wrap: wrap;
        margin-bottom: 2.5rem;
      }

      .footer-contact a,
      .footer-contact button {
        background: none;
        border: none;
        color: var(--text-muted);
        font-size: 0.9rem;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        cursor: pointer;
        transition: color 0.3s ease;
      }

      .footer-contact a:hover,
      .footer-contact button:hover {
        color: var(--accent);
      }

      .footer-actions {
        display: flex;
        justify-content: center;
        gap: 1rem;
        margin-bottom: 3rem;
      }

      .footer-bottom {
        border-top: 1px solid var(--border-color);
        padding-top: 2rem;
        color: var(--text-dark-muted);
        font-size: 0.8rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }

      .footer-bottom a {
        color: var(--text-muted);
        text-decoration: none;
        transition: color 0.3s ease;
      }

      .footer-bottom a:hover {
        color: var(--accent);
      }

      /* --- TOAST NOTIFICATION --- */
      .glass-toast {
        position: fixed;
        bottom: 30px;
        right: 30px;
        background: var(--bg-surface);
        border: 1px solid var(--accent);
        color: var(--text-pure);
        padding: 1rem 1.5rem;
        font-size: 0.9rem;
        font-weight: 500;
        z-index: 1000;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        gap: 0.8rem;
        animation: slideIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
      }

      .glass-toast i {
        color: var(--accent);
      }

      @keyframes slideIn {
        from {
          transform: translateX(120%);
          opacity: 0;
        }
        to {
          transform: translateX(0);
          opacity: 1;
        }
      }

      .animate-spin {
        animation: spin 1.5s linear infinite;
      }

      @keyframes spin {
        100% {
          transform: rotate(360deg);
        }
      }

      /* --- RESPONSIVE MEDIA QUERIES --- */
      @media (max-width: 992px) {
        #custom-cursor {
          display: none !important;
        }
      }

      @media (max-width: 768px) {
        .stats-panel {
          grid-template-columns: 1fr;
        }
        .stat-item {
          border-right: none;
          border-bottom: 1px solid var(--border-color);
        }
        .stat-item:last-child {
          border-bottom: none;
        }
        .footer-contact {
          gap: 1rem;
          flex-direction: column;
          align-items: center;
        }
      }

      @media (max-width: 480px) {
        header {
          padding: 1rem;
        }
        .hero-title {
          font-size: 2.5rem;
        }
        .portal-card {
          padding: 2rem 1.5rem;
        }
        .footer-actions {
          flex-direction: column;
        }
      }
    </style>
  </head>
  <body>
    <div class="glow-orb orb-1"></div>
    <div class="glow-orb orb-2"></div>
    <div id="custom-cursor"></div>

    <header>
      <a href="#" class="brand-logo">
        <i
          class="fa-solid fa-cube"
          style="color: var(--accent); font-size: 1.2rem"
        ></i>
        CMS
      </a>
      <button
        onclick="contactNow()"
        class="btn-premium btn-outline"
        style="padding: 0.6rem 1.5rem"
      >
        <i class="fa-solid fa-phone"></i>
        <span class="hide-mobile">Support</span>
      </button>
    </header>

    <main>
      <div class="section-tag" data-aos="fade-down" data-aos-duration="1000">
        <span class="status-dot"></span> Ecosystem Online
      </div>

      <h1
        class="hero-title"
        data-aos="fade-up"
        data-aos-duration="1200"
        data-aos-delay="200"
      >
        Three Businesses.<br />
        <span class="serif-italic">One Portal.</span>
      </h1>

      <p
        class="hero-desc"
        data-aos="fade-up"
        data-aos-duration="1200"
        data-aos-delay="400"
      >
        Experience your complete business ecosystem with real-time analytics and
        professional management tools designed for growth.
      </p>

      <div
        class="stats-panel"
        data-aos="fade-up"
        data-aos-duration="1200"
        data-aos-delay="600"
      >
        <div class="stat-item">
          <span class="stat-value" id="powder-counter">1,247</span>
          <span class="stat-label">Products Sold</span>
        </div>
        <div class="stat-item">
          <span class="stat-value" id="hostel-occupancy">92%</span>
          <span class="stat-label">Occupancy</span>
        </div>
        <div class="stat-item">
          <span class="stat-value" id="tender-counter">247</span>
          <span class="stat-label">Tenders Filed</span>
        </div>
      </div>

      <div class="portal-grid">
        <div class="portal-card" data-aos="fade-up" data-aos-duration="1000">
          <div class="card-icon-wrapper">
            <i class="fa-solid fa-leaf"></i>
          </div>
          <h3>Dehydrated Powder</h3>
          <p>
            Premium quality food powders. 100% natural, export-ready products
            for the global market with FDA & FSSAI certification.
          </p>
          <div class="feature-icons">
            <i class="fa-solid fa-circle-check"></i>
            <i class="fa-solid fa-globe"></i>
            <i class="fa-solid fa-seedling"></i>
          </div>
          <button
            onclick="openPortal('powder', this)"
            class="btn-premium btn-outline"
          >
            <i class="fa-solid fa-chart-line"></i> View More
          </button>
        </div>

        <div
          class="portal-card"
          data-aos="fade-up"
          data-aos-duration="1000"
          data-aos-delay="150"
        >
          <div class="card-icon-wrapper">
            <i class="fa-solid fa-building"></i>
          </div>
          <h3>Boys Hostel</h3>
          <p>
            Premium accommodation with high-speed WiFi, hygienic food, and 24/7
            security. The best-rated student hostel in the city.
          </p>
          <div class="feature-icons">
            <i class="fa-solid fa-wifi"></i>
            <i class="fa-solid fa-utensils"></i>
            <i class="fa-solid fa-shield-halved"></i>
          </div>
          <button
            onclick="openPortal('hostel', this)"
            class="btn-premium btn-outline"
          >
            <i class="fa-solid fa-calendar-days"></i> Check Availability
          </button>
        </div>

        <div
          class="portal-card"
          data-aos="fade-up"
          data-aos-duration="1000"
          data-aos-delay="300"
        >
          <div class="card-icon-wrapper">
            <i class="fa-solid fa-file-signature"></i>
          </div>
          <h3>E-Tender Services</h3>
          <p>
            Complete tender filing, documentation, and expert consultancy.
            Professional team with a 95% success rate.
          </p>
          <div class="feature-icons">
            <i class="fa-solid fa-check-double"></i>
            <i class="fa-solid fa-clock"></i>
            <i class="fa-solid fa-handshake"></i>
          </div>
          <button
            onclick="openPortal('tender', this)"
            class="btn-premium btn-outline"
          >
            <i class="fa-solid fa-rocket"></i> Start Tender
          </button>
        </div>
      </div>
    </main>

    <footer>
      <div class="footer-brand">ContactMe Services</div>

      <div class="footer-contact">
        <button onclick="contactNow()">
          <i class="fa-solid fa-phone"></i> +91 98765 43210
        </button>
        <button onclick="sendEmail()">
          <i class="fa-solid fa-envelope"></i> hello@contactmeservices.com
        </button>
        <a href="https://www.contactmeservices.com" target="_blank">
          <i class="fa-solid fa-globe"></i> www.contactmeservices.com
        </a>
      </div>

      <div class="footer-actions">
        <button
          onclick="openWhatsApp()"
          class="btn-premium btn-outline"
          style="padding: 0.6rem 1.5rem"
        >
          <i class="fa-brands fa-whatsapp" style="color: #25d366"></i> WhatsApp
        </button>
        <button
          onclick="sendEmail()"
          class="btn-premium btn-outline"
          style="padding: 0.6rem 1.5rem"
        >
          <i class="fa-solid fa-at"></i> Email Us
        </button>
      </div>

      <div class="footer-bottom">
        <p>GST No: 09ABCDE1234F1Z5 &nbsp;|&nbsp; FSSAI: 12345678901234</p>
        <p>
          Redesigned & Developed by
          <a
            href="https://www.linkedin.com/in/shubham-rathod-dev/"
            target="_blank"
          >
            Shubham Rathod
            <i
              class="fa-solid fa-arrow-up-right-from-square"
              style="font-size: 0.7rem"
            ></i>
          </a>
        </p>
      </div>
    </footer>

    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
      // Initialize Scroll Animation
      AOS.init({
        offset: 80,
        delay: 50,
        duration: 800,
        easing: "cubic-bezier(0.25, 1, 0.5, 1)",
        once: true,
      });

      // Smooth Counter Animation on Load
      function animateValue(id, start, end, duration) {
        let obj = document.getElementById(id);
        let startTimestamp = null;
        const step = (timestamp) => {
          if (!startTimestamp) startTimestamp = timestamp;
          const progress = Math.min((timestamp - startTimestamp) / duration, 1);
          const easeOut = progress * (2 - progress); // easeOutQuad
          const currentVal = Math.floor(easeOut * (end - start) + start);

          obj.innerHTML =
            id === "hostel-occupancy"
              ? currentVal + "%"
              : currentVal.toLocaleString();
          if (progress < 1) {
            window.requestAnimationFrame(step);
          }
        };
        window.requestAnimationFrame(step);
      }

      // Live Counter Updates
      function initCounters() {
        setTimeout(() => {
          animateValue("powder-counter", 0, 1247, 2000);
          animateValue("hostel-occupancy", 0, 92, 2000);
          animateValue("tender-counter", 0, 247, 2000);
        }, 500);

        let powderCount = 1247;
        setInterval(() => {
          powderCount += Math.floor(Math.random() * 2);
          document.getElementById("powder-counter").textContent =
            powderCount.toLocaleString();
        }, 3500);

        let hostelOccupancy = 92;
        setInterval(() => {
          hostelOccupancy = 92 + (Math.random() > 0.5 ? 1 : -1);
          if (hostelOccupancy > 98) hostelOccupancy = 98;
          if (hostelOccupancy < 85) hostelOccupancy = 85;
          document.getElementById("hostel-occupancy").textContent =
            hostelOccupancy + "%";
        }, 4000);

        let tenderCount = 247;
        setInterval(() => {
          tenderCount += Math.floor(Math.random() * 2);
          document.getElementById("tender-counter").textContent = tenderCount;
        }, 5000);
      }

      // Action Functions (Portal Routing)
      function openPortal(business, btnElement) {
        const portalNames = {
          powder: "Dehydrated Powder Analytics",
          hostel: "Hostel Management System",
          tender: "E-Tender Dashboard",
        };

        const portalRoutes = {
          powder: "/api/v1/b1",
          hostel: "/api/v1/b2",
          tender: "/api/v1/b3",
        };

        showNotification(
          `Connecting to ${portalNames[business]}...`,
          "fa-spinner animate-spin",
        );

        if (btnElement) {
          btnElement.style.transform = "scale(0.95)";
          setTimeout(() => (btnElement.style.transform = ""), 150);
        }

        setTimeout(() => {
          const targetRoute = portalRoutes[business];
          if (targetRoute) {
            window.location.href = targetRoute;
          }
        }, 800);
      }

      function contactNow() {
        showNotification("Connecting to Support...", "fa-phone");
        setTimeout(() => window.open("tel:+919876543210", "_self"), 800);
      }

      function openWhatsApp() {
        window.open(
          "https://wa.me/919876543210?text=Hello%20ContactMe%20Services,%20I%20have%20an%20inquiry.",
          "_blank",
        );
      }

      function sendEmail() {
        window.open("mailto:hello@contactmeservices.com", "_blank");
      }

      // Custom Codaver Toast Notification
      function showNotification(message, iconClass) {
        const existing = document.querySelector(".glass-toast");
        if (existing) existing.remove();

        const notification = document.createElement("div");
        notification.className = "glass-toast";
        notification.innerHTML = `
          <i class="fa-solid ${iconClass}"></i> 
          <span>${message}</span>
        `;

        document.body.appendChild(notification);

        setTimeout(() => {
          notification.style.opacity = "0";
          notification.style.transform = "translateX(100px)";
          notification.style.transition = "all 0.4s ease";
          setTimeout(() => notification.remove(), 400);
        }, 3000);
      }

      // Desktop Custom Cursor
      if (window.innerWidth > 992) {
        const cursor = document.getElementById("custom-cursor");
        document.addEventListener("mousemove", (e) => {
          cursor.style.left = e.clientX + "px";
          cursor.style.top = e.clientY + "px";
        });

        document.querySelectorAll("a, button, .portal-card").forEach((el) => {
          el.addEventListener("mouseenter", () => {
            cursor.style.width = "40px";
            cursor.style.height = "40px";
            cursor.style.backgroundColor = "rgba(194, 155, 104, 0.1)";
          });
          el.addEventListener("mouseleave", () => {
            cursor.style.width = "20px";
            cursor.style.height = "20px";
            cursor.style.backgroundColor = "transparent";
          });
        });
      }

      // Initialize
      window.onload = function () {
        initCounters();
      };
    </script>
  </body>
</html>
