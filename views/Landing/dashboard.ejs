<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ContactMe Services | Business Portal</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="./Index_CSS/index.css
"
    />
    <script src="https://unpkg.com/lucide@latest"></script>
  </head>
  <body>
    <div class="bg-shapes">
      <div class="shape shape-1"></div>
      <div class="shape shape-2"></div>
    </div>

    <header class="header">
      <div class="logo">CMS<span class="logo-dot"></span></div>
      <button class="btn btn-primary" onclick="contactNow()">
        <i data-lucide="phone-call" style="width: 18px"></i>
        <span class="hide-mobile">Support</span>
      </button>
    </header>

    <section class="hero">
      <h1>Three Businesses.<br />One Portal.</h1>
      <p>
        Experience your complete business ecosystem with real-time analytics and
        professional management tools designed for growth.
      </p>
    </section>

    <main class="portals-container">
      <div class="portal-card" id="powder-portal">
        <div class="icon-wrapper powder-icon">
          <i data-lucide="sprout" size="32"></i>
        </div>
        <h2 class="portal-title">Dehydrated Powder</h2>
        <p class="portal-desc">
          Premium quality food powders. 100% natural, export-ready products for
          the global market with FDA & FSSAI certification.
        </p>

        <div class="feature-list">
          <i data-lucide="badge-check" style="color: var(--accent-powder)"></i>
          <i data-lucide="globe" style="color: var(--accent-powder)"></i>
          <i data-lucide="leaf" style="color: var(--accent-powder)"></i>
        </div>

        <button class="btn btn-outline" onclick="openPortal('powder')">
          <i data-lucide="trending-up" size="18"></i> View Analytics
        </button>
      </div>

      <div class="portal-card" id="hostel-portal">
        <div class="icon-wrapper hostel-icon">
          <i data-lucide="building-2" size="32"></i>
        </div>
        <h2 class="portal-title">Boys Hostel</h2>
        <p class="portal-desc">
          Premium accommodation with high-speed WiFi, hygienic food, and 24/7
          security. The best-rated student hostel in the city.
        </p>

        <div class="feature-list">
          <i data-lucide="wifi" style="color: var(--accent-hostel)"></i>
          <i data-lucide="utensils" style="color: var(--accent-hostel)"></i>
          <i data-lucide="shield-check" style="color: var(--accent-hostel)"></i>
        </div>

        <button class="btn btn-outline" onclick="openPortal('hostel')">
          <i data-lucide="calendar-days" size="18"></i> Check Availability
        </button>
      </div>

      <div class="portal-card" id="tender-portal">
        <div class="icon-wrapper tender-icon">
          <i data-lucide="file-signature" size="32"></i>
        </div>
        <h2 class="portal-title">E-Tender Services</h2>
        <p class="portal-desc">
          Complete tender filing, documentation, and expert consultancy.
          Professional team with a 95% success rate.
        </p>

        <div class="feature-list">
          <i
            data-lucide="check-circle-2"
            style="color: var(--accent-tender)"
          ></i>
          <i data-lucide="clock" style="color: var(--accent-tender)"></i>
          <i data-lucide="handshake" style="color: var(--accent-tender)"></i>
        </div>

        <button class="btn btn-outline" onclick="openPortal('tender')">
          <i data-lucide="rocket" size="18"></i> Start Tender
        </button>
      </div>
    </main>

    <div class="live-stats">
      <div class="stat-box">
        <span class="stat-number" id="powder-counter">1,247</span>
        <span class="stat-label">Products Sold</span>
      </div>
      <div class="stat-box">
        <span class="stat-number" id="hostel-occupancy">92%</span>
        <span class="stat-label">Occupancy Rate</span>
      </div>
      <div class="stat-box">
        <span class="stat-number" id="tender-counter">247</span>
        <span class="stat-label">Tenders Filed</span>
      </div>
    </div>

    <footer class="footer">
      <div style="max-width: 800px; margin: 0 auto">
        <div class="logo" style="justify-content: center; margin-bottom: 20px">
          ContactMe Services<span class="logo-dot"></span>
        </div>

        <div class="contact-info">
          <div class="contact-item" onclick="contactNow()">
            <i data-lucide="phone" size="18"></i>
            <span>+91 98765 43210</span>
          </div>
          <div class="contact-item" onclick="sendEmail()">
            <i data-lucide="mail" size="18"></i>
            <span>hello@contactmeservices.com</span>
          </div>
          <div class="contact-item">
            <i data-lucide="globe" size="18"></i>
            <span
              ><a
                href="https://www.contactmeservices.com"
                style="text-decoration: none; color: #304064"
                >www.contactmeservices.com</a
              >
            </span>
          </div>
        </div>

        <div class="social-buttons">
          <button class="btn btn-outline" onclick="openWhatsApp()">
            <i
              data-lucide="message-circle"
              size="18"
              style="color: #25d366"
            ></i>
            WhatsApp
          </button>
          <button class="btn btn-outline" onclick="sendEmail()">
            <i data-lucide="at-sign" size="18"></i> Email Us
          </button>
        </div>

        <p
          style="
            margin-top: 40px;
            color: var(--text-secondary);
            font-size: 0.9rem;
          "
        >
          <!-- © 2024 ContactMe Services. All rights reserved.<br /> -->
          GST No: 09ABCDE1234F1Z5 | FSSAI: 12345678901234
        </p>

        <div class="developer-signature">
          Redesigned & Developed by <br />
          <a
            href="https://www.linkedin.com/in/shubham-rathod-dev/"
            target="_blank"
            rel="noopener noreferrer"
          >
            Shubham Rathod <i data-lucide="external-link" size="14"></i>
          </a>
        </div>
      </div>
    </footer>

    <style>
      .notification {
        position: fixed;
        bottom: 30px;
        right: 30px;
        background: var(--text-primary);
        color: white;
        padding: 16px 24px;
        border-radius: 12px;
        font-weight: 500;
        z-index: 1000;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
        display: flex;
        align-items: center;
        gap: 12px;
        animation: slideIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
      }

      @keyframes slideIn {
        from {
          transform: translateX(120%);
          opacity: 0;
        }
        to {
          transform: translateX(0);
          opacity: 1;
        }
      }

      @keyframes spin {
        100% {
          transform: rotate(360deg);
        }
      }

      /* Hide text on mobile for small buttons */
      @media (max-width: 480px) {
        .hide-mobile {
          display: none;
        }
      }
    </style>

    <script>
      // Initialize Lucide Icons
      lucide.createIcons();

      // Smooth Counter Animation on Load
      function animateValue(id, start, end, duration) {
        let obj = document.getElementById(id);
        let startTimestamp = null;
        const step = (timestamp) => {
          if (!startTimestamp) startTimestamp = timestamp;
          const progress = Math.min((timestamp - startTimestamp) / duration, 1);

          // easeOutQuad
          const easeOut = progress * (2 - progress);
          const currentVal = Math.floor(easeOut * (end - start) + start);

          obj.innerHTML =
            id === "hostel-occupancy"
              ? currentVal + "%"
              : currentVal.toLocaleString();
          if (progress < 1) {
            window.requestAnimationFrame(step);
          }
        };
        window.requestAnimationFrame(step);
      }

      // Live Counter Updates
      function initCounters() {
        // Initial Animation
        setTimeout(() => {
          animateValue("powder-counter", 0, 1247, 2000);
          animateValue("hostel-occupancy", 0, 92, 2000);
          animateValue("tender-counter", 0, 247, 2000);
        }, 600); // Wait for the fadeSlideUp animation

        // Random live increments
        let powderCount = 1247;
        setInterval(() => {
          powderCount += Math.floor(Math.random() * 2);
          document.getElementById("powder-counter").textContent =
            powderCount.toLocaleString();
        }, 3500);

        let hostelOccupancy = 92;
        setInterval(() => {
          hostelOccupancy = 92 + (Math.random() > 0.5 ? 1 : -1);
          if (hostelOccupancy > 98) hostelOccupancy = 98;
          if (hostelOccupancy < 85) hostelOccupancy = 85;
          document.getElementById("hostel-occupancy").textContent =
            hostelOccupancy + "%";
        }, 4000);

        let tenderCount = 247;
        setInterval(() => {
          tenderCount += Math.floor(Math.random() * 2);
          document.getElementById("tender-counter").textContent = tenderCount;
        }, 5000);
      }

      // Action Functions
      function openPortal(business) {
        const portalNames = {
          powder: "Dehydrated Powder Analytics",
          hostel: "Hostel Management System",
          tender: "E-Tender Dashboard",
        };
        showNotification(
          `Opening ${portalNames[business]}...`,
          "loader-circle",
        );

        // Add a small button press effect
        const btn = event.currentTarget;
        btn.style.transform = "scale(0.95)";
        setTimeout(() => (btn.style.transform = ""), 150);
      }

      function contactNow() {
        showNotification("Connecting to Support...", "phone");
        setTimeout(() => window.open("tel:+919876543210", "_self"), 800);
      }

      function openWhatsApp() {
        window.open(
          "https://wa.me/919876543210?text=Hello%20ContactMe%20Services,%20I%20have%20an%20inquiry.",
          "_blank",
        );
      }

      function sendEmail() {
        window.open("mailto:hello@contactmeservices.com", "_blank");
      }

      // Clean Toast Notification
      function showNotification(message, iconName) {
        const existing = document.querySelector(".notification");
        if (existing) existing.remove();

        const notification = document.createElement("div");
        notification.className = "notification";

        const isLoader = iconName === "loader-circle";
        const iconStyle = isLoader ? "animation: spin 1s linear infinite;" : "";
        const iconColor = iconName === "phone" ? "color: #10b981;" : "";

        notification.innerHTML = `<i data-lucide="${iconName}" style="width:20px; height:20px; ${iconStyle} ${iconColor}"></i> <span>${message}</span>`;

        document.body.appendChild(notification);
        lucide.createIcons();

        setTimeout(() => {
          notification.style.opacity = "0";
          notification.style.transform = "translateX(100px)";
          notification.style.transition = "all 0.4s ease";
          setTimeout(() => notification.remove(), 400);
        }, 3000);
      }

      // Initialize on load
      window.onload = function () {
        initCounters();
      };
    </script>
  </body>
</html>
